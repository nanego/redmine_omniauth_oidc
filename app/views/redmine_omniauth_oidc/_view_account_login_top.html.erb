<% if RedmineOmniauthOidc.enabled? && RedmineOmniauthOidc.oidc_issuer_url.present? %>

<% content_for :header_tags do %>
  <%= stylesheet_link_tag "login", :plugin => "redmine_omniauth_oidc" %>
<% end %>

<div id="oidc-login">
  <%
    @back_url = back_url
    # Unescape back_url on-the-fly — it may be double-escaped behind reverse proxies
    @back_url = CGI.unescape(@back_url) if @back_url && @back_url.match(/^https?%3A/)
  %>
  <%= button_to label_for_oidc_login, :controller => "account", :action => "login_with_oidc_redirect", :origin => @back_url %>

  <% if RedmineOmniauthOidc.second_button_available? %>
    <%= button_to({ :controller => "account", :action => "login_with_oidc_redirect",
                    :origin => @back_url, RedmineOmniauthOidc::SECOND_BUTTON_PARAM => '1' },
                  :class => "oidc-second-button") do %>
      <svg class="oidc-smartcard-icon" viewBox="0 0 24 24" width="18" height="18" fill="none"
           stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="2.5" y="5" width="19" height="14" rx="2.5"></rect>
        <rect x="5.5" y="9" width="4.5" height="4" rx="1"></rect>
        <line x1="13.5" y1="10" x2="18.5" y2="10"></line>
        <line x1="13.5" y1="13.5" x2="18.5" y2="13.5"></line>
      </svg>
      <span class="oidc-second-button-label"><%= label_for_oidc_second_button %></span>
    <% end %>
  <% end %>
</div>

<% end %>
